ClassMethod QuickTest(targetCode As %String, bizId As %String, entryCode As %String="OP_HERB_REFUND", hospId As %String="SC001", deptCode As %String="PHA1")
{
    Set bizInfo = {}
    If entryCode="OP_HERB_DISPEN" {
        Do bizInfo.%Set("data", {"no":(bizId)})
    } Else {
        Do bizInfo.%Set("data", {"id":(bizId)})
    }

    Write ..TestTargetByCode(targetCode, entryCode, hospId, deptCode, bizInfo)
}
