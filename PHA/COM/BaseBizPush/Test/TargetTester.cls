ClassMethod DoInvoke(target As PHA.COM.BaseBizPush.Engine.Target.ITarget, pctx As PHA.COM.BaseBizPush.Engine.Platform.Context.PlatformInvokeContext, bizData As %DynamicObject, ctx As PHA.COM.BaseBizPush.Engine.Context.PushContext) As %Status
