        Continue:'$IsObject(reg.Targets)

        For j=1:1:reg.Targets.Count() {
            Set treg = reg.Targets.GetAt(j)
            Continue:'$IsObject(treg)
            Quit:treg.TargetClass=targetClass treg
        }
